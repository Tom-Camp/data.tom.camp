# Linode Object Storage credentials
LINODE_ACCESS_KEY="your-access-key-id"
LINODE_SECRET_KEY="your-secret-access-key"
LINODE_BUCKET="your-bucket-name"
LINODE_REGION="us-southeast-1"

# Docker Compose project name (check with: docker ps --format '{{.Names}}')
# Default: directory name with dots/special chars stripped, lowercased
COMPOSE_PROJECT_NAME="datatomcamp"

# PostgreSQL credentials (must match prod.env)
POSTGRES_DB="your-database-name"
POSTGRES_USER="your-postgres-user"
POSTGRES_PASS="your-postgres-password"

# Local backup retention (days)
BACKUP_RETENTION_DAYS=7

# Directory to store local backup files
BACKUP_DIR="/var/backups/postgres"
